   if( tile_k > 0 && tile_k < 1 ){                  // Khi biến  0 < k < 1 da giác được thu nhỏ
       cout <<" da giac sau khi phong to: "<< endl ;
       tg_moi.ThuNho( tile_k ) ;
       tg_moi. Xuat() ;
