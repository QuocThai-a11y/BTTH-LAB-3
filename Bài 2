#include <iostream>
#include <cmath>
#include <iomanip>
#include <vector> 
#define M_PI 3.14159265358979323846
#include "DaGiac.h"
using namespace std;
void Diem::nhap(){
    cin >> x >> y ;
}
void Diem::xuat() const {
    cout<<fixed << setprecision(2) <<"(" << x << ", " << y << ")" ;
}
void Diem::tinhTien( double a , double b){       // tịnh tiến x và y
   x += a ;
   y += b ; 
}
void Diem::Quay( double rad ){                 // hàm quay tam giác quanh gốc tọa độ (0 , 0 )
    double x_moi = x*cos(rad) - y*sin(rad) ;
    double y_moi = x*sin(rad) + y*cos(rad) ;
    x = x_moi ; 
    y = y_moi ;
}
void Diem::tiLe( double k ){
    x *= k ;
    y *= k ; 
}
// Đến lớp cDaGiac
void cDaGiac::TinhCanh(){
    // Tim cac canh cua mot da giac 
    dsCanh.clear();
    int n = dsDinh.size();
    for (int i = 0; i < n; i++) {
        Diem d1 = dsDinh[i];
        Diem d2 = dsDinh[(i + 1) % n];
        double canh = sqrt(pow(d1.x - d2.x, 2) + pow(d1.y - d2.y, 2));
        dsCanh.push_back(canh);
    }

}
void cDaGiac::KiemTraDaGiac(){
    TinhCanh() ;
    if( dsDinh.size() < 3 ){  // kiem tra co phai la da giac khong
        cout <<"\nDa giac khong hop le: " ;
        return ;
        }
    vector<double> dsGoc ;         // tao danh sach chua cac goc
    bool CanhBanhNhau = true ; // neu canh bang nhau la true
    bool GocBanhNhau = true ;  // neu goc bang nhau la true 
    bool cungDauDuong = true ;
    bool cungDauAm = true ;
    int n = dsDinh.size() ;
    for( int i = 0 ; i < n ;i++ ){
    
    Diem d1 = dsDinh[(i + n -1)%n] ;                 // Dinh dung truoc
    Diem d2 = dsDinh[i] ;                            // Dinh dung giua 
    Diem d3 = dsDinh[(i+1)%n] ;                      // Dinh dung sau 
    // vector v1 = d1d2 , vector v2 = d2d3 
    double v1x = d1.x-d2.x , v1y = d1.y-d2.y ;
    double v2x = d2.x-d3.x , v2y = d2.y-d3.y ;
    
    double dot = v1x*v2x -v1y*v2y ;           
    double doLon_d1d2 = sqrt(pow(v1x ,2) + pow(v1y ,2)) ;
    double doLon_d2d3 = sqrt(pow(v2x ,2) + pow(v2y ,2)) ;
    double Goc = acos( dot/( doLon_d2d3*doLon_d1d2 ) ) ; // tich vo huong tim goc 
    dsGoc.push_back(Goc) ;
    }
    for( int i = 0 ; i < dsGoc.size() ; i++ ){
    // kiem tra da giac deu 
    double c1 = dsCanh[i] ;
    double c2 = dsCanh[(i+1)%n] ;
    if( abs(c1 - c2) > 1e-6){ CanhBanhNhau = false ; break; }
    if ( abs( dsGoc[i] - dsGoc[(i+1)%n]) > 1e-6){ GocBanhNhau = false; break; }
    // kiem tra da giac lom
    if( dsGoc[i] < 180 ) cungDauAm = false ;
    else if( dsGoc[i] > 180 ) cungDauDuong =  false ;
    }
void cDaGiac::Nhap(){
    int soDinh ;
    cout << "Nhap so luong dinh da giac: " ;
    cin>> soDinh ;
    Diem Dinh_tg ;
    for( int i = 0 ; i < soDinh ; i++){
        cout <<"\nNHap toa do diem " << char('A' + i)<< ": ";
         Dinh_tg.nhap() ;
         dsDinh.push_back(Dinh_tg) ;
    }
    KiemTraDaGiac() ; // kiem tra sau khi nhap 
}
void cDaGiac::Xuat() const {
    cout << "Da giac: ";
        for( int i = 0 ; i < dsDinh.size() ; i++){
            dsDinh[i].xuat() ;
            if(i < dsDinh.size() - 1) cout << ", ";
        }
}
void cDaGiac::tinhChuVi(){          // tinh chu vi
    TinhCanh();
    double sum = 0 ;
    for( int i = 0 ; i < dsCanh.size() ; i++){
        sum += dsCanh[i] ; 
    }
    cout << fixed << setprecision(4) <<"\nChu vi da giac: " << sum ;
}
void cDaGiac::tinhDienTich(){      // tinh dien tich
    TinhCanh();
    int n = dsDinh.size() ;
    double sum = 0 ;
    for( int i = 0 ; i < n ; i++ ){
    Diem d1 = dsDinh[i] ;
    Diem d2 = dsDinh[ (i +1) % n ] ;
    sum += d1.x*d2.y ;
    sum -= d2.x*d1.y ;
    cout << fixed << setprecision(4) <<"\nDien tich da giac: " << abs( sum/2 ) ;
    }
}
void cDaGiac::tinhTien( double a, double b ){         // hàm tịnh tiến 
    for( auto &d: dsDinh ) d.tinhTien(a,b) ;
    }
void cDaGiac::Quay(double goc ){      // hàm quay tam giác quanh gốc tọa độ (0 , 0 )
    double rad = goc*M_PI/180 ;
    for( auto &d: dsDinh ) d.Quay(rad) ;
    }
void cDaGiac::PhongTo( double K ){   // Phóng to
    for( auto &d: dsDinh ) d.tiLe(K) ;
    }
void cDaGiac::ThuNho( double K ){    // thu nhỏ
    for( auto &d: dsDinh ) d.tiLe(K) ;
    }

int main (){
   cDaGiac tg_cu ;
   tg_cu.Nhap() ;
   
