using namespace std;
class Diem {
    public:
    
    double x;
    double y;
    
    Diem( double x1 = 0 , double y1 = 0 ): x(x1) , y(y1){}
    void nhap() ;
    void xuat() const ;
    void tinhTien( double a , double b );
    void Quay( double goc );
    void tiLe( double k );
    
};
class cDaGiac {
    private:
    
      vector<Diem> dsDinh ;
      vector<double> dsCanh ;
      void KiemTraDaGiac();
      void TinhCanh() ;
    public:
    cDaGiac(){}
    
    void Nhap() ;
    
    void tinhDienTich()  ;
    void tinhChuVi()  ;
    void tinhTien( double a , double b );
    void Quay( double gocdo );
    void PhongTo( double k );
