    }
    
    cout << " Nhap "<< n << " so nguyen gom: " ;
    dsSoNguyen.clear() ;
    dsSoNguyen.reserve(n) ;
    for( int i = 0 ; i < n ; i++){
    int SoNguyen ;
    while( !(cin>> SoNguyen) ){
       cout << " Nhap lai so ngyen: " ;
    }
    dsSoNguyen.push_back(SoNguyen) ;
    }
}

void cArray::Xuat() const {    // Xuat gia tri so nguyen
    cout << " { "
    for ( int i = 0 ; i < dsSoNguyen.size(); i++){
    cout << dsSoNguyen[i] << endl ;
    if( i < dsSoNguyen.size() - 1) cout << ", " ;
    }
