}

void cArray::DiemSoNguyen() const {          // Diem so lan cua tung so nguyen 
    int x ; 
    cout << " Nhap gia tri can diem: " ;
    cin >> x ; 
    soLan = count( dsSoNguyen.begin() , dsSoNguyen.end() , x) ;
    cout << " Gia tri " << x << " xuat hien " << soLan ;
    
}
bool cArray::Tangdan() const {          // Kiem tra phan tu co tang dan khong
    for( int i = 0 ; i < dsSoNguyen.size()-1 ; i++){
        if( dsSoNguyen[i] > dsSoNguyen[i+1] ) return false ;
    }
    return true ; 
}

bool SNT( int n ){      // tim so nguyen to 
    if(n < 2) return false ; 
    for( int i = 2 ; i <= sqrt(n); i++){
        if( n%i ==0) return false ; 
            
        }
        return true ;
}

void cArray::SNTMax() const {         // Tim so nguyen so lon nhat
    
    int maxSNT = -1;
    bool coSNT = false;
    for (const auto& x : dsSoNguyen) {
        if (SNT(x) && (x > maxSNT || !coSNT)) {
            maxSNT = x;
            coSNT = true;
        }
    }
    if (coSNT)
        cout << " So nguyen to lon nhat: " << maxSNT << endl;
    else
        cout << " Khong co so nguyen to nao!\n";
}
}

void cArray::SoLeMin() const {               // ham tim so le nho nhat 
    bool coSoLe = false ;
    int minLe = INT_MAX ; 
    for( const auto& x : dsSoNguyen){
        if( x%2 != 0 && x < minLe){
            minLe = x ;
            coSoLe = true ;
        }
    }
    if( coSoLe ) 
        cout << " So le nho nhat: "<< minLe << endl ; 
    else 
        cout << " khong co so le nao!\n" ;
}
void cArray::SapXep(){
    int n = dsSoNguyen.size();
    for (int i = 0; i < n - 1; i++) {
        int min_idx = i;
        for (int j = i + 1; j < n; j++) {
            if (dsSoNguyen[j] < dsSoNguyen[min_idx])
                min_idx = j;
        }
        if (min_idx != i)
            swap(dsSoNguyen[i], dsSoNguyen[min_idx]);
    }
    cout << " Mang sau khi sap xep la: "
    Xuat() ;
}

int main(){
    cArray Mang ; 
    Mang.Nhap() ;
