        if( i > 0) cout  << "x"  ;         // so mu > 0, in bien x
        if( i > 1 ) cout <<"^" << i ;        // so mu > 1, in dau ^ mu cho bien x 
        if( dshangSo[i-1] != 0 || (i-1) != 0){       // khi so cuoi cung co gia tri bang 0, bo '+' va 0
        if( i-1 < soMu && i > 0 ) cout << (dshangSo[i] > 0 ? "+":"-") ;
        }   
        
    }
