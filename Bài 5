#ifndef DATHUC_h
#define DATHUC_h
#include <iostream>
#include <vector>
using namespace std;

class DaThuc{
    private:
    
    vector<double> dshangSo ;
    
    public:
    DaThuc(){}
    void Nhap() ;
    void Xuat() const;
    double TinhGiaTri( double a) const ;
    void ChuanHoa() ;
    DaThuc operator+(const DaThuc& other) const ;
    DaThuc operator-(const DaThuc& other) const ;

    ~DaThuc(){}
};
#endif

#include <iostream>
#include <vector>
#include <cmath>
#include <algorithm>
#include "DaThuc.h"
using namespace std;

void DaThuc::Nhap(){
    cout << " Nhap bac cua da thuc: " ;
    
    int soMu ;
     
    while( !(cin >> soMu) || soMu < 0){
        cout << " Loi! Nhap lai bac cua da thuc: ";
        cin >> soMu ;
    }
    
    dshangSo.resize(soMu+1) ;
    cout << " Nhap " << soMu+1 <<" he so cho da thuc: " ;
    
    for(int i = 0 ; i <= soMu ; i++){
        cin >> dshangSo[i] ;
    }
}
void DaThuc::Xuat() const {
    if( dshangSo.empty() ){ 
        cout<< "0" << endl;
        return ;
    }
    
    bool isFirst = true ;
    
    for( int i = dshangSo.size() - 1 ; i >= 0 ; i--){
        if( dshangSo[i] == 0 ) continue ;
        
        if(!isFirst) cout << (dshangSo[i]>0 ? "+":"-") ;
        else if( dshangSo[i] < 0)  cout << "-" ;
        
        double HeSo = abs(dshangSo[i]) ;
        if( i == 0 || HeSo != 1) cout << HeSo ;
        if( i > 0 ) cout << "x" ;
        if( i > 1 ) cout << "^" << i ;
        
        isFirst = false ;
    }
    if(isFirst) cout << "0" << endl;
}
double DaThuc::TinhGiaTri( double x ) const {
    
    double sum = 0.0 ;
    
    for( int i = dshangSo.size()-1 ;  i>= 0 ; i-- ){
        sum += dshangSo[i]*pow(x , i) ;
    }
    return sum ;

}
void DaThuc::ChuanHoa() {
    while (dshangSo.size() > 1 && dshangSo.back() == 0) {
        dshangSo.pop_back();
    }
}
DaThuc DaThuc::operator+(const DaThuc& other) const {
    DaThuc Ketqua ;
    int max_size = max( this->dshangSo.size() , other.dshangSo.size()) ;
    Ketqua.dshangSo.resize( max_size , 0.0) ;
    
    for( int i = 0 ; i < max_size ; i++){
    double heSo1 = (i < this->dshangSo.size()) ? this->dshangSo[i] : 0.0 ;
    double heSo2 = (i < other.dshangSo.size()) ? other.dshangSo[i] : 0.0 ;
    Ketqua.dshangSo[i] = heSo1 + heSo2 ;
    }
    // xoa he so 0 o bac cao nhat
    Ketqua.ChuanHoa() ;
    return Ketqua ;
}
DaThuc DaThuc::operator-(const DaThuc& other) const {
    DaThuc Ketqua ;
    int max_size = max( this->dshangSo.size() , other.dshangSo.size()) ;
    
    Ketqua.dshangSo.resize( max_size ) ;
    for( int i = 0 ; i < max_size ; i++){
    double heSo1 = (i < this->dshangSo.size()) ? this->dshangSo[i] : 0.0 ;
    double heSo2 = (i < other.dshangSo.size()) ? other.dshangSo[i] : 0.0 ;
    
    Ketqua.dshangSo[i] = heSo1 - heSo2 ;
    }
    // xoa he so 0 o bac cao nhat
    Ketqua.ChuanHoa() ;
    return Ketqua ;
}

int main(){
    DaThuc dt1 , dt2 ;
    cout <<" Khai bao da thuc 1: " << endl;;
    dt1.Nhap() ;
    dt1.Xuat() ;
    
    cout <<" Khai bao da thuc 2: "<< endl ;
    dt2.Nhap() ;
    dt2.Xuat() ;
    
    cout <<" Nhap tri bien x: " ;
    double x ;
    cin >> x ;
    
    cout << "P1(" << x << ") = " << dt1.TinhGiaTri(x) << endl;
    cout << "P2(" << x << ") = " << dt2.TinhGiaTri(x) << endl;

    cout << "\nTong hai da thuc: ";
    DaThuc dt3 = dt1 + dt2;
    dt3.Xuat();
    
    cout << "\nHieu hai da thuc: ";
    DaThuc dt4 = dt1 - dt2;
    dt4.Xuat();
    return 0;
}
